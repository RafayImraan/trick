generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires     DateTime
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions     Session[]
  stealthKeys  StealthKey[]
  PaymentLinks PaymentLink[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StealthKey {
  id           String   @id @default(cuid())
  userId       String
  publicKey    String
  privateKey   String  @default("")
  address      String  @unique
  balance      String  @default("0")
  createdAt    DateTime @default(now())
  isActive     Boolean @default(true)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  PaymentLink   PaymentLink?
}

model PaymentLink {
  id           String   @id @default(cuid())
  userId       String
  linkCode     String   @unique
  stealthKeyId String?  @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  clickCount   Int      @default(0)

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stealthKey  StealthKey? @relation(fields: [stealthKeyId], references: [id])
}

model Transaction {
  id            String   @id @default(cuid())
  stealthKeyId  String
  txHash        String   @unique
  fromAddress  String
  toAddress    String
  amount       String
  token        String   @default("TRX")
  status       String   @default("pending")
  blockNumber Int?
  timestamp    DateTime @default(now())

  stealthKey   StealthKey @relation(fields: [stealthKeyId], references: [id], onDelete: Cascade)
}
